{
  "compilerOptions": {
    "target": "ES6",                       // ou "ES2017" ou plus si besoin
    "module": "ES6",                       // <-- le plus important
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node"            // <-- ajoute ceci
  }
}
